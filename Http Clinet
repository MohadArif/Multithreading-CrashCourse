RestTemplate :- Example

✅ Step 1: Create RestTemplate Bean
@Configuration
public class AppConfig {

    @Bean
    public RestTemplate restTemplate() {
        return new RestTemplate();
    }
}
✅ Step 2: Create DTO
@Data
@AllArgsConstructor
@NoArgsConstructor
public class Post {

    private Long userId;
    private Long id;
    private String title;
    private String body;
}
✅ Step 3: Create Service (CRUD)
@Service
public class PostService {

    @Autowired
    private RestTemplate restTemplate;

    private final String BASE_URL = "https://jsonplaceholder.typicode.com/posts";

    // 🔹 CREATE (POST)
    public Post createPost(Post post) {
        return restTemplate.postForObject(BASE_URL, post, Post.class);
    }

    // 🔹 READ (GET by ID)
    public Post getPostById(Long id) {
        return restTemplate.getForObject(BASE_URL + "/" + id, Post.class);
    }

    // 🔹 READ (GET ALL)
    public List<Post> getAllPosts() {
        Post[] posts = restTemplate.getForObject(BASE_URL, Post[].class);
        return Arrays.asList(posts);
    }

    // 🔹 UPDATE (PUT)
    public String updatePost(Long id, Post post) {
        restTemplate.put(BASE_URL + "/" + id, post);
        return "Updated Successfully";
    }

    // 🔹 DELETE
    public String deletePost(Long id) {
        restTemplate.delete(BASE_URL + "/" + id);
        return "Deleted Successfully";
    }
}

